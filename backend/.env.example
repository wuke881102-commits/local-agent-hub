# ─── 文本模型：阿里百炼 / DashScope（OpenAI 兼容端点）─────────────────
# 文档：https://bailian.console.aliyun.com  →  「模型广场」
# DashScope 的 OpenAI 兼容端点固定为：https://dashscope.aliyuncs.com/compatible-mode/v1
# TEXT_MODEL 填你账号开通的 model id（注意不是所有模型都默认可用，需在百炼开通）
# 已验证可用：qwen3.7-plus  常见候选：qwen-plus / qwen-max / qwen3.7-max / qwen3.6-flash
TEXT_MODEL_PROVIDER=openai_compatible
TEXT_MODEL=qwen3.7-plus
TEXT_MODEL_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TEXT_MODEL_API_KEY=sk-your-dashscope-key
# 仅 azure provider 用到（保持空即可）
TEXT_MODEL_AZURE_ENDPOINT=
TEXT_MODEL_API_VERSION=2024-12-01-preview

# ─── 视觉模型：Azure OpenAI ────────────────────────────────────────
# 重要：VISION_MODEL 填 Azure 上的 deployment 名（不是模型名！）
# 查 deployment 名：Azure 门户 → OpenAI 资源 → 「模型部署」页签
# 或调用：curl ${AZURE_ENDPOINT}openai/deployments?api-version=2023-03-15-preview \
#         -H "api-key: ${KEY}"
# 当前已知部署示例：gpt-4.1-mini-2025-04-14 (model=gpt-4.1-mini)
VISION_MODEL_PROVIDER=azure
VISION_MODEL=gpt-4.1-mini-2025-04-14
VISION_MODEL_AZURE_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
VISION_MODEL_API_VERSION=2024-12-01-preview
VISION_MODEL_API_KEY=your-azure-subscription-key
# openai_compatible 时才用到（azure 不需要）
VISION_MODEL_BASE_URL=

# ─── Feishu CLI ────────────────────────────────────────────────────
# 飞书 CLI 二进制路径或命令名。安装方法见 README 与 scripts/install-lark-cli.cmd
LARK_CLI_BIN=lark-cli
ENABLE_MOCK_FALLBACK=true

# ─── App ───────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8787
LOCAL_INDEX_DB=./data/index.sqlite
DRAFT_DIR=./data/drafts
LOG_DIR=./data
FRONTEND_DEV_ORIGIN=http://127.0.0.1:5173
CONFIG_DIR=../config
